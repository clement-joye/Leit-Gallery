# Azure Storage Configuration (for uploading gallery audio files)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=saleitgallery;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=gallery

# Path to Leit main repository (for seed_gallery.py)
LEIT_CORE_PATH=../Leit

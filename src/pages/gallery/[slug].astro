---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import Base from "@/layouts/Base.astro";
import AudioSection from "@/components/AudioSection.astro";
import MetricsPanel from "@/components/MetricsPanel.astro";
import SignaturePanel from "@/components/SignaturePanel.astro";
import ProfilePanel from "@/components/ProfilePanel.astro";
import BadgeSnippet from "@/components/BadgeSnippet.astro";
import galleryData from "@/data/gallery.json";
import { url } from "@/utils/url";

export function getStaticPaths() {
  return galleryData.entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const storageBase = galleryData.storage_base_url;

const profileRaw = readFileSync(resolve(`scripts/output/${entry.slug}/profile.json`), "utf-8");
const signatureRaw = readFileSync(resolve(`scripts/output/${entry.slug}/signature.json`), "utf-8");
const profile = JSON.parse(profileRaw);
const signature = JSON.parse(signatureRaw);

function formatGenre(genre: string) {
  return genre.replace(/_/g, " ");
}
---

<Base title={`${entry.name} — Leit Gallery`} description={`Listen to the musical signature of ${entry.name} (${entry.repo})`}>
  <main class="mx-auto flex w-full max-w-5xl flex-col gap-8 px-6 py-10 sm:px-8 lg:px-10">
    <!-- Header -->
    <section class="space-y-4">
      <a href={url("/")} class="inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-violet-300 transition">
        ← Back to gallery
      </a>
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="space-y-2">
          <h1 class="text-3xl font-semibold text-white sm:text-4xl">{entry.name}</h1>
          <p class="text-sm text-zinc-400">{entry.description}</p>
          <div class="flex flex-wrap gap-2 text-xs">
            <span class="rounded-full border border-violet-400/20 bg-violet-500/10 px-3 py-1 font-medium capitalize text-violet-300">
              {formatGenre(entry.genre)}
            </span>
            <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1 text-zinc-400">
              {entry.language}
            </span>
            <a
              href={`https://github.com/${entry.repo}`}
              target="_blank"
              rel="noopener"
              class="rounded-full border border-white/10 bg-black/20 px-3 py-1 text-zinc-400 hover:text-white transition"
            >
              {entry.repo}
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-violet-400/20 bg-violet-500/10 px-4 py-3 text-right">
          <p class="text-xs uppercase tracking-[0.25em] text-violet-300">Tempo</p>
          <p class="text-2xl font-semibold text-white">{entry.tempo} BPM</p>
        </div>
      </div>
    </section>

    <section class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur">
      <p class="text-sm text-zinc-300">
        Leit turns repository metrics into a code profile, a deterministic musical signature, and a WAV render.
        Those artifacts can then be used as a starting point for Gemini or another generative AI model to produce a more interpretive track while keeping the repository identity intact.
      </p>
    </section>

    <!-- Audio Player -->
    <AudioSection entry={entry} storageBase={storageBase} />

    <!-- Metrics -->
    <MetricsPanel entry={entry} />

    <!-- Musical Signature -->
    <SignaturePanel signature={signature} />

    <!-- Code Profile -->
    <ProfilePanel profile={profile} />

    <!-- Technical Details -->
    <section class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur">
      <h2 class="text-sm font-medium uppercase tracking-[0.3em] text-violet-300 mb-4">Technical details</h2>
      <div class="grid gap-4 sm:grid-cols-2 text-sm">
        <div>
          <p class="text-xs uppercase tracking-wider text-zinc-500">Commit analyzed</p>
          <p class="mt-1 font-mono text-zinc-200">{entry.commit_sha}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-zinc-500">Generated at</p>
          <p class="mt-1 text-zinc-200">{new Date(entry.generated_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-zinc-500">Musical key</p>
          <p class="mt-1 text-zinc-200">{entry.key}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-zinc-500">Module count</p>
          <p class="mt-1 text-zinc-200">{entry.metrics.module_count.toLocaleString()}</p>
        </div>
      </div>
    </section>

    <!-- Badge -->
    <BadgeSnippet entry={entry} />
  </main>
</Base>
